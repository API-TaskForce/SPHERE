{
  "SPHERE": {
    "entityTypes": {
      "User": {
        "shape": {
          "type": "Record",
          "attributes": {
            "username": { "type": "String" },
            "email":    { "type": "String" },
            "userType": { "type": "String" }
          }
        }
      },

      "Organization": {
        "shape": {
          "type": "Record",
          "attributes": {
            "name":       { "type": "String" },
            "isPersonal": { "type": "Boolean" }
          }
        }
      },

      "OrganizationMembership": {
        "shape": {
          "type": "Record",
          "attributes": {
            "role":         { "type": "String" },
            "organization": { "type": "Entity", "name": "SPHERE::Organization" },
            "user":         { "type": "Entity", "name": "SPHERE::User" }
          }
        }
      },

      "Group": {
        "memberOfTypes": ["Group"],
        "shape": {
          "type": "Record",
          "attributes": {
            "name":         { "type": "String" },
            "organization": { "type": "Entity", "name": "SPHERE::Organization" },
            "isRoot":       { "type": "Boolean" }
          }
        }
      },

      "GroupMembership": {
        "shape": {
          "type": "Record",
          "attributes": {
            "role":         { "type": "String" },
            "group":        { "type": "Entity", "name": "SPHERE::Group" },
            "organization": { "type": "Entity", "name": "SPHERE::Organization" },
            "user":         { "type": "Entity", "name": "SPHERE::User" }
          }
        }
      },

      "PricingCollection": {
        "shape": {
          "type": "Record",
          "attributes": {
            "name":         { "type": "String" },
            "organization": { "type": "Entity", "name": "SPHERE::Organization" }
          }
        }
      },

      "Pricing": {
        "shape": {
          "type": "Record",
          "attributes": {
            "name":       { "type": "String" },
            "collection": { "type": "Entity", "name": "SPHERE::PricingCollection" },
            "creator":    { "type": "Entity", "name": "SPHERE::User" }
          }
        }
      }
    },

    "actions": {
      "createOrganization": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Organization"]
        }
      },
      "readOrganization": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Organization"]
        }
      },
      "updateOrganization": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Organization"]
        }
      },
      "deleteOrganization": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Organization"]
        }
      },
      "manageOrganizationMembers": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Organization"]
        }
      },
      "manageSubscription": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Organization"]
        }
      },

      "createGroup": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Organization"]
        }
      },
      "createSubgroup": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Group"]
        }
      },
      "readGroup": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Group"]
        }
      },
      "updateGroup": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Group"]
        }
      },
      "deleteGroup": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Group"]
        }
      },
      "manageGroupMembers": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Group"]
        }
      },
      "manageGroupCollections": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Group"]
        }
      },

      "createCollection": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Organization"]
        }
      },
      "readCollection": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["PricingCollection"]
        }
      },
      "updateCollection": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["PricingCollection"]
        }
      },
      "deleteCollection": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["PricingCollection"]
        }
      },

      "createPricing": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["PricingCollection"]
        }
      },
      "readPricing": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Pricing"]
        }
      },
      "updatePricing": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Pricing"]
        }
      },
      "deletePricing": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Pricing"]
        }
      }
    }
  }
}
